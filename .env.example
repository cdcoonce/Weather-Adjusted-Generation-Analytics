MOCK_START_DATE=2023-01-01
MOCK_END_DATE=2024-12-31
MOCK_ASSET_COUNT=10
MOCK_RANDOM_SEED=42

# dbt Configuration
DBT_PROFILES_DIR=/Users/cdcoonce/Documents/GitHub/Weather_Adjusted_Generation_Analytics/dbt/renewable_dbt/profiles
