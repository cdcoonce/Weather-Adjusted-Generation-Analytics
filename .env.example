# ──────────────────────────────────────────────────────────────────────
# WAGA Snowflake Environment Variables
# ──────────────────────────────────────────────────────────────────────
# All variables below are required for the WAGA pipeline to connect
# to Snowflake. Used by the WAGASnowflakeResource in Dagster.

# Snowflake account identifier (e.g. xy12345.us-east-1)
WAGA_SNOWFLAKE_ACCOUNT=

# Service-account username (not a personal user)
WAGA_SNOWFLAKE_USER=

# Base64-encoded PEM private key (PKCS#8, no passphrase)
# Generate with:
#   openssl genrsa 2048 | openssl pkcs8 -topk8 -nocrypt -outform PEM | base64 -w0
WAGA_SNOWFLAKE_PRIVATE_KEY_BASE64=

# Compute warehouse name
WAGA_SNOWFLAKE_WAREHOUSE=

# Target database (default: WAGA)
WAGA_SNOWFLAKE_DATABASE=WAGA

# Snowflake role
WAGA_SNOWFLAKE_ROLE=

# ──────────────────────────────────────────────────────────────────────
# Minimum Snowflake Role Grants
# ──────────────────────────────────────────────────────────────────────
# The role specified above needs at minimum:
#
#   GRANT USAGE ON WAREHOUSE <warehouse> TO ROLE <role>;
#   GRANT USAGE ON DATABASE WAGA TO ROLE <role>;
#   GRANT USAGE ON ALL SCHEMAS IN DATABASE WAGA TO ROLE <role>;
#   GRANT CREATE SCHEMA ON DATABASE WAGA TO ROLE <role>;
#   GRANT CREATE TABLE ON ALL SCHEMAS IN DATABASE WAGA TO ROLE <role>;
#   GRANT CREATE VIEW ON ALL SCHEMAS IN DATABASE WAGA TO ROLE <role>;
#   GRANT SELECT ON ALL TABLES IN DATABASE WAGA TO ROLE <role>;
#   GRANT INSERT, UPDATE, DELETE ON ALL TABLES IN DATABASE WAGA TO ROLE <role>;
